generator client {
  provider      = "prisma-client-js"
  // Native = local dev (mac/linux). rhel = AWS Lambda (Amazon Linux 2023, x86_64).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum SourceType {
  canvas
  sharepoint
}

// Terminal outcome of the most recent completed remediation cycle for a source_file.
// NULL on source_file.last_outcome means "cycle in progress or not yet attempted".
enum LastOutcome {
  completed
  completed_with_warnings
  failed
  permanently_failed
  deleted
}

enum WritebackState {
  written
  skipped_stale
  failed
}

enum BatchStatus {
  pending
  completed
  completed_with_warnings
  failed
  cancelled
}

enum QualityLabel {
  Excellent
  Good
  RequiresReview  @map("requires_review")
  Failed          @map("quality_failed")
  Unchanged
}

enum ConnectivoFileState {
  completed
  completed_with_warnings
  failed
}

model Institution {
  id             String     @id @default(uuid())
  name           String     @db.VarChar(255)
  slug           String     @unique @db.VarChar(100)
  sourceType     SourceType @map("source_type")
  credentials    Json
  writebackOptIn Boolean    @default(false) @map("writeback_opt_in")

  // Sync scheduling. syncTime is "HH:MM" in UTC (e.g. "02:00"). The tick handler
  // (EventBridge every 15 min) enqueues a discover if sync_enabled=true AND current
  // time is within syncTime's 15-min window AND lastSyncedAt < start of today.
  // S3 bucket override. NULL = convention-based name (sparient-<institutionId>).
  // Set only when a client needs a non-standard bucket name.
  s3Bucket     String?   @map("s3_bucket") @db.VarChar(63)

  syncEnabled  Boolean   @default(true)  @map("sync_enabled")
  syncTime     String    @default("02:00") @map("sync_time") @db.VarChar(5)
  lastSyncedAt DateTime? @map("last_synced_at")

  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  courses Course[]
  batches Batch[]

  @@map("institutions")
}

model Course {
  id             String    @id @default(uuid())
  institutionId  String    @map("institution_id")
  canvasCourseId String    @map("canvas_course_id") @db.VarChar(100)
  canvasTermId   String?   @map("canvas_term_id") @db.VarChar(100)
  name           String    @db.VarChar(255)
  courseCode     String?   @map("course_code") @db.VarChar(100)
  writebackOptIn Boolean?  @map("writeback_opt_in")
  lastSyncedAt   DateTime? @map("last_synced_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  institution Institution  @relation(fields: [institutionId], references: [id])
  sourceFiles SourceFile[]
  batches     Batch[]

  @@unique([institutionId, canvasCourseId])
  @@index([institutionId])
  @@map("courses")
}

// Pipeline position is derived from three monotonic timestamps, not a status column.
// See FILE_STATUSES.md for the full state-derivation rules.
model SourceFile {
  id                      String          @id @default(uuid())
  courseId                String          @map("course_id")
  canvasFileId            String          @map("canvas_file_id") @db.VarChar(100)
  displayName             String          @map("display_name") @db.VarChar(500)
  fileName                String          @map("file_name") @db.VarChar(500)
  mimeType                String          @map("mime_type") @db.VarChar(100)
  sizeBytes               BigInt?         @map("size_bytes")

  // Latest modified_at we have seen from Canvas
  discoveredModifiedAt    DateTime        @map("discovered_modified_at")

  // Content-addressed S3 upload. s3SourceModifiedAt pins the version that key corresponds to.
  s3SourceKey             String?         @map("s3_source_key") @db.VarChar(1000)
  s3SourceBucket          String?         @map("s3_source_bucket") @db.VarChar(255)
  s3SourceModifiedAt      DateTime?       @map("s3_source_modified_at")

  // Version currently in-flight at Connectivo (set by BatchBuilder claim). Never cleared
  // on success — a newer s3SourceModifiedAt naturally makes the row re-eligible for batching.
  batchedModifiedAt       DateTime?       @map("batched_modified_at")

  lastOutcome             LastOutcome?    @map("last_outcome")
  lastFailureReason       String?         @map("last_failure_reason")
  retryCount              Int             @default(0) @map("retry_count")
  maxRetries              Int             @default(3) @map("max_retries")
  nextRetryAt             DateTime?       @map("next_retry_at")

  writebackState          WritebackState? @map("writeback_state")
  lastWritebackModifiedAt DateTime?       @map("last_writeback_modified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course     Course      @relation(fields: [courseId], references: [id])
  batchFiles BatchFile[]

  @@unique([courseId, canvasFileId])
  @@index([courseId])
  @@index([lastOutcome])
  @@map("source_files")
}

model Batch {
  id                String      @id @default(uuid())
  institutionId     String      @map("institution_id")
  courseId          String      @map("course_id")
  // Their internal UUID. Populated when we receive their response.json (kept for audit
  // / log correlation). The matching key for response → batch is the S3 file path,
  // not this column.
  connectivoBatchId String?     @map("connectivo_batch_id") @db.VarChar(255)
  status            BatchStatus @default(pending)
  isInitialSync     Boolean     @default(false) @map("is_initial_sync")
  isRetry           Boolean     @default(false) @map("is_retry")
  requestS3Bucket   String?     @map("request_s3_bucket") @db.VarChar(255)
  requestS3Key      String?     @map("request_s3_key") @db.VarChar(1000)
  requestWrittenAt  DateTime?   @map("request_written_at")
  completedAt       DateTime?   @map("completed_at")
  totalFiles        Int         @default(0) @map("total_files")
  totalPages        Int?        @map("total_pages")
  succeeded         Int?
  failed            Int?
  requiresReview    Int?        @map("requires_review")
  totalIssuesFound  Int?        @map("total_issues_found")
  totalIssuesFixed  Int?        @map("total_issues_fixed")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  institution Institution @relation(fields: [institutionId], references: [id])
  course      Course      @relation(fields: [courseId], references: [id])
  batchFiles  BatchFile[]

  @@index([institutionId])
  @@index([courseId])
  @@index([status])
  @@map("batches")
}

// A batch_file pins the exact s3_source_key + modifiedAt that was handed to Connectivo.
// Immutable after creation — edits to the underlying file produce a new batch_file, not a mutation.
model BatchFile {
  id                 String               @id @default(uuid())
  batchId            String               @map("batch_id")
  sourceFileId       String               @map("source_file_id")
  canvasFileId       String               @map("canvas_file_id") @db.VarChar(100)
  s3SourceKey        String               @map("s3_source_key") @db.VarChar(1000)
  sourceModifiedAt   DateTime             @map("source_modified_at")
  connectivoState    ConnectivoFileState? @map("connectivo_state")
  qualityLabel       QualityLabel?        @map("quality_label")
  remediatedS3Key    String?              @map("remediated_s3_key") @db.VarChar(1000)
  remediatedS3Bucket String?              @map("remediated_s3_bucket") @db.VarChar(255)
  totalPages           Int?                 @map("total_pages")
  processingTimeSecs   Int?                 @map("processing_time_seconds")
  complianceErrors     Int?                 @map("compliance_errors")
  complianceWarnings   Int?                 @map("compliance_warnings")
  totalIssuesFound     Int?                 @map("total_issues_found")
  totalIssuesFixed     Int?                 @map("total_issues_fixed")
  errorMessage         String?              @map("error_message")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  batch           Batch               @relation(fields: [batchId], references: [id])
  sourceFile      SourceFile          @relation(fields: [sourceFileId], references: [id])
  issueCategories FileIssueCategory[]

  @@index([batchId])
  @@index([sourceFileId])
  @@map("batch_files")
}

model FileIssueCategory {
  id          String @id @default(uuid())
  batchFileId String @map("batch_file_id")
  category    String @db.VarChar(100)
  found       Int    @default(0)
  fixed       Int    @default(0)
  remaining   Int    @default(0)
  issues      Json   @default("[]") // Array of { name, status, detail }

  batchFile BatchFile @relation(fields: [batchFileId], references: [id])

  @@index([batchFileId])
  @@map("file_issue_categories")
}

