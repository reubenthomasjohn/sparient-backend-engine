{
  "info": {
    "name": "Sparient Backend Engine",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",            "value": "http://localhost:3000" },
    { "key": "canvasDomain",       "value": "your-institution.instructure.com" },
    { "key": "canvasApiToken",     "value": "your-canvas-api-token" },
    { "key": "canvasAccountId",    "value": "1" },
    { "key": "institutionId",      "value": "" },
    { "key": "courseId",           "value": "" },
    { "key": "batchId",            "value": "" },
    { "key": "canvasFileId",       "value": "" },
    { "key": "canvasUploadUrl",    "value": "", "description": "Auto-populated by the 'Upload step 1' test script from the response's upload_url. Don't edit by hand." },
    { "key": "canvasConfirmUrl",   "value": "", "description": "Auto-populated by the 'Upload step 2' test script from the Location header. Don't edit by hand." }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Canvas API (Direct)",
      "description": "Test Canvas API directly — bypasses our engine. Useful for verifying credentials and exploring data before running a sync.",
      "item": [
        {
          "name": "List courses in account",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{canvasApiToken}}" }
            ],
            "url": {
              "raw": "https://{{canvasDomain}}/api/v1/accounts/{{canvasAccountId}}/courses?state[]=available&enrollment_type=teacher&per_page=10",
              "host": ["https://{{canvasDomain}}"],
              "path": ["api", "v1", "accounts", "{{canvasAccountId}}", "courses"],
              "query": [
                { "key": "state[]",         "value": "available" },
                { "key": "enrollment_type", "value": "teacher" },
                { "key": "per_page",        "value": "10" }
              ]
            }
          }
        },
        {
          "name": "List enrollment terms for account",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{canvasApiToken}}" }
            ],
            "url": {
              "raw": "https://{{canvasDomain}}/api/v1/accounts/{{canvasAccountId}}/terms",
              "host": ["https://{{canvasDomain}}"],
              "path": ["api", "v1", "accounts", "{{canvasAccountId}}", "terms"]
            }
          }
        },
        {
          "name": "List files in a course",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{canvasApiToken}}" }
            ],
            "url": {
              "raw": "https://{{canvasDomain}}/api/v1/courses/{{courseId}}/files?sort=updated_at&order=desc&per_page=20&content_types[]=application/pdf&content_types[]=application/vnd.openxmlformats-officedocument.wordprocessingml.document&content_types[]=application/vnd.openxmlformats-officedocument.presentationml.presentation&content_types[]=application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
              "host": ["https://{{canvasDomain}}"],
              "path": ["api", "v1", "courses", "{{courseId}}", "files"],
              "query": [
                { "key": "sort",            "value": "updated_at" },
                { "key": "order",           "value": "desc" },
                { "key": "per_page",        "value": "20" },
                { "key": "content_types[]", "value": "application/pdf" },
                { "key": "content_types[]", "value": "application/vnd.openxmlformats-officedocument.wordprocessingml.document" },
                { "key": "content_types[]", "value": "application/vnd.openxmlformats-officedocument.presentationml.presentation" },
                { "key": "content_types[]", "value": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" }
              ]
            }
          }
        },
        {
          "name": "Get a single file",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{canvasApiToken}}" }
            ],
            "url": {
              "raw": "https://{{canvasDomain}}/api/v1/files/{{canvasFileId}}",
              "host": ["https://{{canvasDomain}}"],
              "path": ["api", "v1", "files", "{{canvasFileId}}"]
            }
          }
        },
        {
          "name": "Upload step 1: notify Canvas",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Captures upload_url so step 2 can POST to it without manual copy/paste.",
                  "const r = pm.response.json();",
                  "if (r.upload_url) pm.collectionVariables.set('canvasUploadUrl', r.upload_url);",
                  "if (r.upload_params) console.log('upload_params (paste into step 2 body):', r.upload_params);"
                ]
              }
            }
          ],
          "request": {
            "description": "Step 1 of Canvas's 3-step file upload. Canvas responds with upload_url + upload_params. The test script auto-sets {{canvasUploadUrl}} and logs upload_params to the Postman console — copy them into step 2's form body.\n\non_duplicate=overwrite (default) replaces in place when name + parent_folder_id match an existing file (same file id preserved). on_duplicate=rename forces a new file.\n\nparent_folder_id is optional — omit to upload to the course root folder.",
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{canvasApiToken}}" },
              { "key": "Content-Type",  "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name",             "value": "remediated.pdf" },
                { "key": "size",             "value": "12345" },
                { "key": "content_type",     "value": "application/pdf" },
                { "key": "parent_folder_id", "value": "",               "disabled": true },
                { "key": "on_duplicate",     "value": "overwrite" }
              ]
            },
            "url": {
              "raw": "https://{{canvasDomain}}/api/v1/courses/{{courseId}}/files",
              "host": ["https://{{canvasDomain}}"],
              "path": ["api", "v1", "courses", "{{courseId}}", "files"]
            }
          }
        },
        {
          "name": "Upload step 2: POST bytes to upload_url",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// If Canvas returned a 3xx redirect, capture Location for step 3. If it returned",
                  "// 201 with the file object, we're done — clear canvasConfirmUrl as a signal.",
                  "const loc = pm.response.headers.get('Location');",
                  "if (pm.response.code >= 300 && pm.response.code < 400 && loc) {",
                  "  pm.collectionVariables.set('canvasConfirmUrl', loc);",
                  "  console.log('Redirected — run step 3 next.');",
                  "} else {",
                  "  pm.collectionVariables.set('canvasConfirmUrl', '');",
                  "  console.log('201 received — upload complete, skip step 3.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "description": "Step 2. POST multipart/form-data to {{canvasUploadUrl}} (auto-set by step 1). Fill in every field from step 1's upload_params (logged in the Postman console), then the file field LAST — ordering matters. Do NOT send the Authorization header; upload_url is on Inst-FS, not the Canvas API host.\n\nOn 201: the response body IS the file object — done. On 3xx: the test script captures Location into {{canvasConfirmUrl}}, run step 3.",
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{canvasUploadUrl}}",
              "host": ["{{canvasUploadUrl}}"]
            }
          }
        },
        {
          "name": "Upload step 3: confirm",
          "request": {
            "description": "Only needed when step 2 returned a 3xx. POST empty (Content-Length: 0) to the captured {{canvasConfirmUrl}}. Bearer token IS required here — this request is back on the Canvas API host.",
            "method": "POST",
            "header": [
              { "key": "Authorization",  "value": "Bearer {{canvasApiToken}}" },
              { "key": "Content-Length", "value": "0" }
            ],
            "url": {
              "raw": "{{canvasConfirmUrl}}",
              "host": ["{{canvasConfirmUrl}}"]
            }
          }
        },
        {
          "name": "Delete a file",
          "request": {
            "description": "Used by supersedeFile after the replacement upload succeeds.",
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{canvasApiToken}}" }
            ],
            "url": {
              "raw": "https://{{canvasDomain}}/api/v1/files/{{canvasFileId}}",
              "host": ["https://{{canvasDomain}}"],
              "path": ["api", "v1", "files", "{{canvasFileId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Institutions (Internal)",
      "description": "Institution-level admin operations.",
      "item": [
        {
          "name": "Wipe institution data",
          "request": {
            "method": "DELETE",
            "description": "Deletes all courses, source files, batches, batch files, and issue categories for the institution. The institution row itself is preserved. Useful for resetting before a clean re-sync.",
            "url": "{{baseUrl}}/api/v1/institutions/{{institutionId}}/data"
          }
        }
      ]
    },
    {
      "name": "Sync (Internal)",
      "description": "Enqueues a discovery job. Returns 200 once the job is on the queue (does not wait for the sync to finish). Watch server logs to track progress.",
      "item": [
        {
          "name": "Trigger full institution sync",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/sync/institutions/{{institutionId}}"
          }
        },
        {
          "name": "Force full institution re-sync",
          "request": {
            "method": "POST",
            "description": "Clears lastSyncedAt on all courses and resets discovered_modified_at to epoch, so every file is treated as changed on the next discovery pass regardless of its current state.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/sync/institutions/{{institutionId}}?force=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sync", "institutions", "{{institutionId}}"],
              "query": [
                { "key": "force", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Trigger single course sync",
          "request": {
            "method": "POST",
            "description": "courseId is the Canvas course ID (e.g. 114), not the internal UUID.",
            "url": "{{baseUrl}}/api/v1/sync/institutions/{{institutionId}}/courses/{{courseId}}"
          }
        },
        {
          "name": "Force single course re-sync",
          "request": {
            "method": "POST",
            "description": "Resets lastSyncedAt and discovered_modified_at for this course only, forcing all its files to be re-queued.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/sync/institutions/{{institutionId}}/courses/{{courseId}}?force=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sync", "institutions", "{{institutionId}}", "courses", "{{courseId}}"],
              "query": [
                { "key": "force", "value": "true" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Batches (Internal)",
      "item": [
        {
          "name": "Get batch by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/batches/{{batchId}}"
          }
        },
        {
          "name": "Get files in a batch",
          "request": {
            "description": "Returns batch_files with the pinned s3SourceKey and sourceModifiedAt for each file.",
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/batches/{{batchId}}/files"
          }
        },
        {
          "name": "List batches for institution",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/batches/institutions/{{institutionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "batches", "institutions", "{{institutionId}}"],
              "query": [
                { "key": "status",   "value": "pending",       "disabled": true },
                { "key": "courseId", "value": "{{courseId}}",  "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Stuck batches",
          "request": {
            "description": "Returns pending batches whose request.json was written to S3 more than N hours ago without a response. Pure observability — no remediation triggered.",
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/batches/stuck?olderThanHours=24",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "batches", "stuck"],
              "query": [
                { "key": "olderThanHours", "value": "24" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "description": "Internal admin operations for testing and the monolith / single-Lambda env.",
      "item": [
        {
          "name": "Process response manually",
          "request": {
            "method": "POST",
            "description": "Reads response.json from the responses S3 bucket at the conventional path and processes it as if the responses Lambda had received it via S3 event. Use for testing or in the single-Lambda env where there is no S3 → SQS → Lambda chain.",
            "url": "{{baseUrl}}/api/v1/admin/responses/{{institutionId}}/{{courseId}}/{{batchId}}"
          }
        }
      ]
    }
  ]
}
