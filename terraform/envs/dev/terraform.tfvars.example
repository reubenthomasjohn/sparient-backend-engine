region      = "us-east-2"
name_prefix = "sparient-dev"

# S3 buckets are per-institution (sparient-<institutionId>), created dynamically.
# No global bucket variable needed.

# Concurrency caps
discovery_max_concurrency = 5
api_provisioned_concurrency = 0

# CI/CD
github_repo_name = "sparient-backend-engine"

# NOTE: neon_api_key is NOT in this file.
# Pass via: export TF_VAR_neon_api_key=napi_...
# In CI: pulled from GitHub Actions secret NEON_API_KEY.
