# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://sparient:sparient@localhost:5432/sparient

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_SOURCE_BUCKET=
S3_REMEDIATED_BUCKET=

# Canvas (used when seeding an institution record during local dev)
CANVAS_DOMAIN=
CANVAS_ACCOUNT_ID=
CANVAS_API_TOKEN=

# Institution slug — used in S3 paths (e.g. s3://bucket/sparient/courses/...)
# Lowercase, alphanumeric and hyphens only. Must be unique across institutions.
# Defaults to the first part of CANVAS_DOMAIN if not set.
INSTITUTION_SLUG=

# Connectivo
# Generate with: openssl rand -hex 32
CONNECTIVO_API_KEY_SECRET=

# Retry job config
RETRY_BASE_DELAY_MINUTES=30
RETRY_CRON_SCHEDULE=0 */2 * * *

# Nightly sync config
SYNC_CRON_SCHEDULE=0 2 * * *
