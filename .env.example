# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://sparient:sparient@localhost:5432/sparient

# AWS (optional locally — SDK uses default credential chain)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
S3_SOURCE_BUCKET=
S3_REMEDIATED_BUCKET=
S3_REQUESTS_BUCKET=sparient-remediation-requests
S3_RESPONSES_BUCKET=sparient-remediation-responses

# Canvas (used when seeding an institution record during local dev)
CANVAS_DOMAIN=https://sparient.instructure.com
CANVAS_ACCOUNT_ID=1
CANVAS_API_TOKEN=29625~ACnHwMhKzt4JDDcwvEZBrA82K6VcLufEJ3JQkHtEK4xU8JRKWGTfXWPMnhZP4tAt

# Institution slug — used in S3 paths
INSTITUTION_SLUG=

# Retry backoff base (kept for observability — does not drive scheduling)
RETRY_BASE_DELAY_MINUTES=30

# Queue — leave unset for local dev (uses in-memory queue)
# SQS_DISCOVERY_URL=
QUEUE_START_CONSUMERS=true

# Step Functions — unset locally (SyncOrchestrator falls back to inline execution)
# COURSE_WORKFLOW_ARN=

# Access Hub API — HTTP Basic (TASK-01). Defaults apply when unset (password enforced in production).
# ACCESS_HUB_BASIC_USER=access-hub
# ACCESS_HUB_BASIC_PASSWORD=local-dev-secret

# Access Hub API — HMAC-SHA256 signed auth (TASK-12 / §5.3).
# If X-Signature header is present on a request, signed auth is used (no Basic fallback).
# If X-Signature is absent, Basic auth is used instead.
#
# ACCESS_HUB_SIGNING_SECRETS — JSON map of signing secrets.
#   Key "*" = global deployment secret (allowed for any institution).
#   Key "<institution_uuid>" = per-institution secret (bound to that institution only).
#   Example: ACCESS_HUB_SIGNING_SECRETS={"*":"global-secret","<uuid>":"per-inst-secret"}
# ACCESS_HUB_SIGNING_SECRETS=
#
# ACCESS_HUB_SIGNING_ALLOWED_INSTITUTIONS — comma-separated institution UUIDs allowed for the global key.
#   Omit or leave empty to allow all institutions for the global key.
# ACCESS_HUB_SIGNING_ALLOWED_INSTITUTIONS=
#
# ACCESS_HUB_SIGNING_SKEW_SECONDS — clock skew tolerance (default 300 = ±5 min).
# ACCESS_HUB_SIGNING_SKEW_SECONDS=300
