# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://sparient:sparient@localhost:5432/sparient

# AWS (optional locally — SDK uses default credential chain)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
# S3 bucket is per-institution: sparient-<institutionId> (or institution.s3Bucket override).
# No global S3_BUCKET env var — bucket name is resolved at runtime via getBucketName().

# Canvas (used when seeding an institution record during local dev)
CANVAS_DOMAIN=
CANVAS_ACCOUNT_ID=
CANVAS_API_TOKEN=

# Institution slug — used in S3 paths
INSTITUTION_SLUG=

# Retry backoff base (kept for observability — does not drive scheduling)
RETRY_BASE_DELAY_MINUTES=30

# Queue — leave unset for local dev (uses in-memory queue)
# SQS_DISCOVERY_URL=
QUEUE_START_CONSUMERS=true

# Step Functions — unset locally (SyncOrchestrator falls back to inline execution)
# COURSE_WORKFLOW_ARN=
